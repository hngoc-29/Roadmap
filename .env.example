# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/roadmap-builder

# Base URL của app (không có dấu / cuối)
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tên app (dùng cho metadata & JSON-LD)
NEXT_PUBLIC_APP_NAME="Interactive Roadmap Builder"

# Secret key cho On-demand ISR revalidation
# Tạo bằng: openssl rand -hex 32
REVALIDATION_SECRET=your-secret-here

# ============================================================
# GITHUB OAUTH - Đăng nhập bằng GitHub
# ============================================================
# 1. Vào https://github.com/settings/developers
# 2. "New OAuth App"
# 3. Homepage URL: http://localhost:3000
# 4. Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# NextAuth secret (tạo bằng: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
