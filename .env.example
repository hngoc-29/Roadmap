# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/roadmap-builder?retryWrites=true&w=majority

# Next.js App URL (dùng cho OpenGraph & Sitemap)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# App Name
NEXT_PUBLIC_APP_NAME="Interactive Roadmap Builder"

# Admin Secret (bảo vệ API routes)
ADMIN_SECRET=your-super-secret-key-here

# Revalidation Secret (dùng cho On-Demand ISR)
REVALIDATION_SECRET=your-revalidation-secret
